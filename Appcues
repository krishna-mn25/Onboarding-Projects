<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Appcues × MonetizeNow</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blue:    #0521AB;
  --lb:      #D3EEF4;
  --lb2:     #EBF6FA;
  --white:   #FFFFFF;
  --off:     #F7F9FE;
  --border:  #E4EAF8;
  --dark:    #0D1526;
  --sub:     #6B7A99;
  --green:   #166534;
  --green-b: #DCFCE7;
  --green-br:#BBF7D0;
  --amber:   #92400E;
  --amber-b: #FEF3C7;
  --amber-br:#FDE68A;
  --red:     #991B1B;
  --red-b:   #FEE2E2;
  --red-br:  #FECACA;
  --gray-b:  #F1F5F9;
  --gray-br: #CBD5E1;
  --gray-t:  #475569;
}

html, body { width:100%; height:100%; overflow:hidden; background:#0D1526; font-family:'DM Sans',sans-serif; }
#deck { position:relative; width:100vw; height:100vh; overflow:hidden; }

.slide {
  position:absolute; inset:0; display:flex; flex-direction:column;
  opacity:0; pointer-events:none; transform:translateX(40px);
  transition:opacity 0.42s cubic-bezier(.4,0,.2,1), transform 0.42s cubic-bezier(.4,0,.2,1);
  overflow:hidden;
}
.slide.active { opacity:1; pointer-events:all; transform:translateX(0); }

/* NAV */
#nav {
  position:fixed; bottom:28px; left:50%; transform:translateX(-50%);
  display:flex; align-items:center; gap:12px; z-index:100;
  background:rgba(13,21,38,0.88); backdrop-filter:blur(12px);
  padding:10px 20px; border-radius:40px; border:1px solid rgba(255,255,255,0.1);
}
.nav-btn { width:36px; height:36px; border-radius:50%; border:1.5px solid rgba(255,255,255,0.2); background:rgba(255,255,255,0.08); color:white; font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.2s; }
.nav-btn:hover { background:rgba(255,255,255,0.16); border-color:rgba(255,255,255,0.4); }
.nav-btn:disabled { opacity:0.3; cursor:default; }
#slide-counter { font-size:12px; color:rgba(255,255,255,0.5); font-weight:500; letter-spacing:0.08em; min-width:44px; text-align:center; }
.nav-dots { display:flex; gap:6px; align-items:center; }
.nav-dot { width:6px; height:6px; border-radius:50%; background:rgba(255,255,255,0.25); cursor:pointer; transition:background 0.2s,transform 0.2s; }
.nav-dot.active { background:var(--lb); transform:scale(1.3); }
#kbd-hint { position:fixed; bottom:28px; right:32px; font-size:11px; color:rgba(255,255,255,0.25); letter-spacing:0.05em; z-index:100; }

/* CHROME */
.slide-chrome { display:flex; justify-content:space-between; align-items:center; padding:16px 52px; flex-shrink:0; }
.slide-tag { font-size:11px; font-weight:500; letter-spacing:0.05em; }
.pg { font-size:11px; font-weight:500; }
.chrome-light { border-bottom:1px solid var(--border); background:var(--white); }
.chrome-light .slide-tag { color:var(--sub); }
.chrome-light .pg { color:#B0B8D0; }
.chrome-dark { border-bottom:1px solid rgba(255,255,255,0.1); }
.chrome-dark .slide-tag { color:rgba(255,255,255,0.45); }

/* LOGO LOCKUP */
.logo-lockup { display:flex; align-items:center; gap:10px; }
.logo-lockup img { height:28px; width:28px; border-radius:6px; object-fit:contain; }
.logo-lockup .logo-name { font-size:14px; font-weight:700; letter-spacing:-0.02em; }
.chrome-light .logo-lockup .logo-name { color:var(--blue); }
.chrome-dark .logo-lockup .logo-name { color:white; }
.logo-sep { font-size:13px; color:rgba(255,255,255,0.3); margin:0 4px; }
.chrome-light .logo-sep { color:#CBD5E1; }

/* SLIDE TYPES */
.slide.light { background:var(--white); }
.slide.off { background:var(--off); }
.slide.dark { background:var(--blue); }
.slide-body { flex:1; padding:0 52px 80px; overflow:hidden; display:flex; flex-direction:column; }

/* PAGE HEADING */
.ph { margin-bottom:28px; padding-top:28px; }
.ph-eye { font-size:11px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--blue); margin-bottom:8px; }
.ph h2 { font-family:'DM Serif Display',serif; font-size:34px; font-weight:400; color:var(--dark); line-height:1.15; letter-spacing:-0.01em; }
.dark .ph-eye { color:var(--lb); }
.dark .ph h2 { color:white; }

/* COVER */
.cover-body { flex:1; display:flex; flex-direction:column; justify-content:center; padding:0 52px 80px; }

/* COVER LOGO LOCKUP — larger */
.cover-logos {
  display:flex; align-items:center; gap:16px; margin-bottom:32px;
}
.cover-logos .c-logo {
  display:flex; align-items:center; gap:10px;
}
.cover-logos img {
  height:36px; width:36px; border-radius:8px; object-fit:contain;
  background:white; padding:2px;
}
.cover-logos .c-logo-name {
  font-size:18px; font-weight:700; letter-spacing:-0.02em; color:white;
}
.cover-logos .c-logo-name.appcues { color:white; }
.cover-logos .cross {
  font-size:20px; font-weight:300; color:rgba(255,255,255,0.35); margin:0 4px;
}

.cover-h1 { font-family:'DM Serif Display',serif; font-size:54px; font-weight:400; line-height:1.06; color:white; margin-bottom:20px; max-width:700px; letter-spacing:-0.01em; }
.cover-h1 em { color:var(--lb); font-style:italic; }
.cover-sub { font-size:16px; font-weight:300; color:rgba(255,255,255,0.6); max-width:520px; line-height:1.65; margin-bottom:34px; }
.pill-row { display:flex; gap:8px; flex-wrap:wrap; }
.pill { font-size:11px; font-weight:500; padding:6px 14px; border-radius:20px; }
.pill-ghost { color:white; border:1px solid rgba(255,255,255,0.22); background:rgba(255,255,255,0.1); }
.pill-lb { color:var(--blue); background:var(--lb); }
.cover-foot { display:flex; justify-content:space-between; align-items:center; padding:18px 52px; border-top:1px solid rgba(255,255,255,0.12); flex-shrink:0; }
.cover-foot span { font-size:11px; color:rgba(255,255,255,0.35); letter-spacing:0.05em; }

/* STATS */
.statbar { display:flex; gap:3px; margin-bottom:28px; flex-shrink:0; }
.stat { flex:1; background:var(--lb2); border:1px solid #C8E4EF; border-radius:10px; padding:18px 16px; text-align:center; }
.stat-n { font-family:'DM Serif Display',serif; font-size:24px; color:var(--blue); line-height:1; margin-bottom:5px; }
.stat-l { font-size:11px; color:var(--sub); font-weight:500; }

/* CALLOUTS */
.co { border-radius:10px; padding:14px 18px; font-size:13px; line-height:1.65; margin-bottom:16px; flex-shrink:0; }
.co-blue { background:#EBF2FF; border-left:3px solid var(--blue); color:var(--dark); }
.co-blue strong { color:var(--blue); }
.co-amber { background:var(--amber-b); border-left:3px solid #D97706; color:var(--amber); }
.co-amber strong { font-weight:700; }
.co-green { background:var(--green-b); border-left:3px solid #16A34A; color:var(--green); }
.co-green strong { font-weight:700; }

/* GRIDS */
.g2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
.flex-row { display:flex; gap:24px; }
.flex-row > * { flex:1; }

/* CARDS */
.card { background:var(--white); border:1px solid var(--border); border-radius:12px; padding:22px 24px; }
.card.blue-tint { background:var(--lb2); border-color:#C8E4EF; }
.card.gray-tint { background:var(--gray-b); border-color:var(--gray-br); }

/* CHECKLIST */
.cl { list-style:none; }
.cl li { display:flex; gap:12px; align-items:flex-start; padding:9px 0; border-bottom:1px solid var(--border); }
.cl li:last-child { border-bottom:none; }
.cl-dot { width:7px; height:7px; min-width:7px; border-radius:50%; background:var(--blue); margin-top:6px; flex-shrink:0; }
.cl li strong { display:block; font-size:14px; font-weight:600; color:var(--dark); line-height:1.3; }
.cl li span { font-size:12px; color:var(--sub); display:block; margin-top:2px; line-height:1.45; }

/* TAGS */
.tag { display:inline-block; font-size:9px; font-weight:700; letter-spacing:0.09em; text-transform:uppercase; padding:3px 8px; border-radius:20px; }
.tag-blue { background:var(--blue); color:white; }
.tag-lb { background:var(--lb); color:var(--blue); }
.tag-green { background:var(--green-b); color:var(--green); border:1px solid var(--green-br); }
.tag-amber { background:var(--amber-b); color:var(--amber); border:1px solid var(--amber-br); }
.tag-red { background:var(--red-b); color:var(--red); border:1px solid var(--red-br); }
.tag-gray { background:var(--gray-b); color:var(--gray-t); border:1px solid var(--gray-br); }

/* MODEL SPLIT */
.model { display:flex; gap:3px; margin-bottom:20px; }
.model-side { flex:1; border-radius:12px; padding:24px 22px; }
.model-side.green { background:#F0FDF4; border:1px solid var(--green-br); }
.model-side.blue-s { background:#EBF2FF; border:1px solid #C3D3F7; }
.model-pct { font-family:'DM Serif Display',serif; font-size:54px; line-height:1; margin-bottom:8px; }
.model-side.green .model-pct { color:#16A34A; }
.model-side.blue-s .model-pct { color:var(--blue); }
.model-title { font-size:15px; font-weight:600; margin-bottom:6px; color:var(--dark); }
.model-desc { font-size:13px; color:var(--sub); line-height:1.55; }
.model-vs { display:flex; align-items:center; justify-content:center; width:36px; flex-shrink:0; font-size:11px; font-weight:600; color:#B0B8D0; }

/* CATALOG */
.cat { border:1px solid var(--border); border-radius:10px; overflow:hidden; margin-bottom:8px; }
.cat:last-child { margin-bottom:0; }
.cat-h { background:var(--lb2); border-bottom:1px solid #C8E4EF; padding:11px 16px; display:flex; justify-content:space-between; align-items:center; gap:8px; }
.cat-name { font-size:14px; font-weight:600; color:var(--dark); }
.cat-b { padding:12px 16px; }
.cat-b p { font-size:13px; color:var(--sub); line-height:1.5; margin-bottom:5px; }
.cat-b .meta { font-size:11px; color:#94A3B8; font-weight:500; }

/* OFFERINGS */
.off { border:1.5px solid #BDD4EA; border-radius:10px; overflow:hidden; margin-bottom:10px; }
.off:last-child { margin-bottom:0; }
.off-h { background:var(--blue); padding:11px 16px; display:flex; justify-content:space-between; align-items:center; }
.off-h.legacy { background:#475569; }
.off-h h4 { font-size:14px; font-weight:600; color:white; }
.off-h span { font-size:11px; color:rgba(255,255,255,0.6); }
.off-b { padding:11px 16px; }
.off-row { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid var(--border); font-size:13px; color:var(--dark); }
.off-row:last-child { border-bottom:none; }
.req { font-size:9px; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; padding:2px 7px; border-radius:4px; background:var(--green-b); color:var(--green); border:1px solid var(--green-br); }
.opt { font-size:9px; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; padding:2px 7px; border-radius:4px; background:var(--amber-b); color:var(--amber); border:1px solid var(--amber-br); }

/* SECTION LABEL */
.sec-label { font-size:10px; font-weight:700; letter-spacing:0.13em; text-transform:uppercase; color:var(--sub); margin-bottom:10px; }

/* TIMELINE */
.tl { display:flex; align-items:flex-start; margin:4px 0 20px; }
.tl-step { flex:1; text-align:center; position:relative; }
.tl-dot { width:34px; height:34px; border-radius:50%; background:var(--blue); color:white; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; position:relative; z-index:1; }
.tl-dot.future { background:var(--lb2); color:var(--blue); border:2px solid #B0CFDB; }
.tl-connector { position:absolute; top:17px; left:calc(50% + 17px); right:calc(-50% + 17px); height:2px; background:var(--lb); }
.tl-connector.done { background:var(--blue); opacity:0.4; }
.tl-week { font-size:10px; font-weight:700; letter-spacing:0.09em; text-transform:uppercase; color:var(--blue); margin-bottom:4px; }
.tl-lbl { font-size:12px; font-weight:600; color:var(--dark); }
.tl-sub { font-size:10px; color:var(--sub); margin-top:2px; line-height:1.35; }

/* FLOW */
.flow { display:flex; align-items:center; margin-bottom:4px; }
.fstep { flex:1; text-align:center; background:var(--lb2); border:1px solid #C8E4EF; border-radius:8px; padding:13px 8px; }
.fstep.white { background:white; border-color:var(--border); }
.fstep-num { font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--blue); margin-bottom:4px; }
.fstep-label { font-size:13px; font-weight:600; color:var(--dark); line-height:1.3; }
.fstep-sub { font-size:11px; color:var(--sub); margin-top:3px; line-height:1.3; }
.farrow { font-size:18px; color:#B0C0D8; padding:0 5px; flex-shrink:0; }

/* TABLE */
table { width:100%; border-collapse:collapse; }
th { background:var(--blue); color:white; padding:11px 16px; font-size:12px; font-weight:600; letter-spacing:0.03em; text-align:left; }
td { padding:10px 16px; border-bottom:1px solid var(--border); font-size:13px; color:var(--dark); vertical-align:top; }
tr:last-child td { border-bottom:none; }
tr:nth-child(even) td { background:#FAFBFF; }
td strong { font-weight:600; }

/* MIGRATION PHASE */
.mig { border-radius:12px; border:1px solid var(--border); overflow:hidden; margin-bottom:10px; }
.mig:last-child { margin-bottom:0; }
.mig-h { display:flex; align-items:center; gap:14px; padding:14px 20px; }
.mig-h.ph0 { background:var(--blue); }
.mig-h.ph1 { background:#EBF2FF; border-bottom:1px solid #C3D3F7; }
.mig-h.ph2 { background:var(--gray-b); border-bottom:1px solid var(--gray-br); }
.mig-num { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; flex-shrink:0; }
.ph0 .mig-num { background:rgba(255,255,255,0.18); color:white; }
.ph1 .mig-num { background:var(--blue); color:white; }
.ph2 .mig-num { background:#CBD5E1; color:#334155; }
.mig-title { font-size:14px; font-weight:600; }
.ph0 .mig-title { color:white; }
.ph1 .mig-title { color:var(--dark); }
.ph2 .mig-title { color:#475569; }
.mig-sub { font-size:11px; margin-top:1px; }
.ph0 .mig-sub { color:rgba(255,255,255,0.6); }
.ph1 .mig-sub,.ph2 .mig-sub { color:var(--sub); }
.mig-badge { margin-left:auto; font-size:11px; font-weight:600; padding:4px 10px; border-radius:12px; white-space:nowrap; flex-shrink:0; }
.ph0 .mig-badge { background:rgba(255,255,255,0.18); color:white; }
.ph1 .mig-badge { background:var(--blue); color:white; }
.ph2 .mig-badge { background:#E2E8F0; color:#475569; }
.mig-b { padding:14px 20px; display:grid; grid-template-columns:1fr 1fr; gap:10px 20px; }
.mig-item strong { display:block; font-size:13px; font-weight:600; color:var(--dark); margin-bottom:2px; }
.mig-item span { font-size:12px; color:var(--sub); line-height:1.45; }
.mig-outcome { grid-column:span 2; background:var(--lb2); border:1px solid #C8E4EF; border-radius:8px; padding:10px 14px; font-size:13px; color:var(--dark); }
.mig-outcome strong { color:var(--blue); }

/* TIMER BOXES */
.timer-row { display:flex; gap:3px; margin-bottom:12px; }
.tbox { flex:1; border-radius:10px; padding:16px; text-align:center; border:1px solid var(--border); }
.tbox.fast { background:var(--green-b); border-color:var(--green-br); }
.tbox.slow { background:var(--amber-b); border-color:var(--amber-br); }
.tbox.risk { background:var(--red-b); border-color:var(--red-br); }
.tbox-n { font-family:'DM Serif Display',serif; font-size:28px; margin-bottom:4px; }
.fast .tbox-n { color:#16A34A; }
.slow .tbox-n { color:#B45309; }
.risk .tbox-n { color:var(--red); }
.tbox-lbl { font-size:12px; font-weight:600; margin-bottom:3px; }
.fast .tbox-lbl { color:var(--green); }
.slow .tbox-lbl { color:var(--amber); }
.risk .tbox-lbl { color:var(--red); }
.tbox-desc { font-size:11px; color:var(--sub); line-height:1.45; }

/* V7 BADGE */
.v7-badge { display:inline-flex; align-items:center; gap:5px; background:linear-gradient(135deg,#0521AB 0%,#1592C4 100%); color:white; font-size:11px; font-weight:600; padding:4px 11px; border-radius:20px; letter-spacing:0.02em; }

/* CLOSING */
.closing-body { flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; padding:0 52px 80px; }
.closing-h1 { font-family:'DM Serif Display',serif; font-size:50px; color:white; line-height:1.1; margin-bottom:14px; max-width:700px; }
.closing-h1 em { color:var(--lb); font-style:italic; }
.closing-sub { font-size:16px; font-weight:300; color:rgba(255,255,255,0.6); max-width:520px; line-height:1.65; margin-bottom:40px; }
.closing-cards { display:flex; gap:14px; max-width:780px; width:100%; margin-bottom:32px; }
.cc { flex:1; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.16); border-radius:12px; padding:20px 18px; text-align:left; }
.cc-eye { font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--lb); margin-bottom:7px; }
.cc-title { font-size:15px; font-weight:600; color:white; margin-bottom:6px; }
.cc-desc { font-size:12px; color:rgba(255,255,255,0.5); line-height:1.55; }
.closing-foot { font-size:11px; color:rgba(255,255,255,0.28); letter-spacing:0.05em; }

/* CLOSING LOGO ROW */
.closing-logo-row { display:flex; align-items:center; gap:20px; margin-bottom:32px; }
.closing-logo-row img { height:40px; width:40px; border-radius:10px; object-fit:contain; background:white; padding:3px; }
.closing-logo-row .cl-name { font-size:18px; font-weight:700; color:white; letter-spacing:-0.02em; }
.closing-logo-row .cl-cross { font-size:20px; color:rgba(255,255,255,0.3); margin:0 6px; }

.mb8{margin-bottom:8px} .mb12{margin-bottom:12px} .mb16{margin-bottom:16px}
.mb20{margin-bottom:20px} .mb24{margin-bottom:24px} .mb28{margin-bottom:28px}
</style>
</head>
<body>
<div id="deck">


<!-- S1: COVER -->
<div class="slide dark active" id="s1">
  <div class="slide-chrome chrome-dark">
    <div class="logo-lockup">
      <img src="https://avatars.githubusercontent.com/u/5355844?s=80&v=4" alt="Appcues" onerror="this.style.display='none'">
      <span class="logo-name">Appcues</span>
      <span class="logo-sep">×</span>
      <img src="https://avatars.githubusercontent.com/u/131706261?s=80&v=4" alt="MonetizeNow" onerror="this.style.display='none'">
      <span class="logo-name">MonetizeNow</span>
    </div>
    <div class="slide-tag">Implementation Kickoff · May 2026</div>
  </div>
  <div class="cover-body">
    <div class="cover-logos">
      <div class="c-logo">
        <img src="https://avatars.githubusercontent.com/u/5355844?s=120&v=4" alt="Appcues" onerror="this.style.display='none'">
        <span class="c-logo-name appcues">Appcues</span>
      </div>
      <span class="cross">×</span>
      <div class="c-logo">
        <img src="https://avatars.githubusercontent.com/u/131706261?s=120&v=4" alt="MonetizeNow" onerror="this.style.display='none'">
        <span class="c-logo-name">MonetizeNow</span>
      </div>
    </div>
    <h1 class="cover-h1">Your quote-to-cash motion,<br><em>built the right way.</em></h1>
    <p class="cover-sub">Catalog, quoting, Salesforce sync, and a phased AI-assisted migration that gets reps selling before historicals are fully imported.</p>
    <div class="pill-row">
      <span class="pill pill-ghost">CPQ</span>
      <span class="pill pill-ghost">Salesforce</span>
      <span class="pill pill-lb">6-Week Implementation</span>
      <span class="pill pill-ghost">Phased Migration</span>
      <span class="pill pill-ghost">80 / 20 Model</span>
    </div>
  </div>
  <div class="cover-foot">
    <span>Prepared by MonetizeNow CX</span>
    <span>Confidential · Appcues Implementation</span>
  </div>
</div>


<!-- S2: CONTEXT -->
<div class="slide light" id="s2">
  <div class="slide-chrome chrome-light">
    <div class="logo-lockup">
      <img src="https://avatars.githubusercontent.com/u/131706261?s=80&v=4" alt="MonetizeNow" onerror="this.style.display='none'">
      <span class="logo-name">MonetizeNow</span>
    </div>
    <div class="slide-tag">Appcues · May 2026</div>
