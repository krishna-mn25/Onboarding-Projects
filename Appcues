  <div class="nav-dots" id="dots"></div>
  <span id="slide-counter">1 / 9</span>
  <button class="nav-btn" id="btn-next" onclick="go(1)">→</button>
</div>
<div id="kbd-hint">← → or click to navigate</div>

<script>
const slides = document.querySelectorAll('.slide');
const dotsEl = document.getElementById('dots');
const counter = document.getElementById('slide-counter');
const btnPrev = document.getElementById('btn-prev');
const btnNext = document.getElementById('btn-next');
let current = 0, transitioning = false;

slides.forEach((_, i) => {
  const d = document.createElement('div');
  d.className = 'nav-dot' + (i === 0 ? ' active' : '');
  d.onclick = () => goTo(i);
  dotsEl.appendChild(d);
});

function updateNav() {
  document.querySelectorAll('.nav-dot').forEach((d, i) => d.classList.toggle('active', i === current));
  counter.textContent = `${current + 1} / ${slides.length}`;
  btnPrev.disabled = current === 0;
  btnNext.disabled = current === slides.length - 1;
}

function goTo(idx) {
  if (transitioning || idx === current || idx < 0 || idx >= slides.length) return;
  transitioning = true;
  const prev = slides[current], next = slides[idx];
  const fwd = idx > current;
  next.style.transition = 'none';
  next.style.transform = fwd ? 'translateX(40px)' : 'translateX(-40px)';
  next.style.opacity = '0';
  next.style.pointerEvents = 'none';
  requestAnimationFrame(() => requestAnimationFrame(() => {
    next.style.transition = '';
    next.style.transform = 'translateX(0)';
    next.style.opacity = '1';
    next.style.pointerEvents = 'all';
    prev.style.transition = 'opacity 0.38s cubic-bezier(.4,0,.2,1), transform 0.38s cubic-bezier(.4,0,.2,1)';
    prev.style.transform = fwd ? 'translateX(-40px)' : 'translateX(40px)';
    prev.style.opacity = '0';
    prev.style.pointerEvents = 'none';
    current = idx;
    updateNav();
    setTimeout(() => { prev.style.transform = fwd ? 'translateX(40px)' : 'translateX(-40px)'; transitioning = false; }, 420);
  }));
}

function go(dir) { goTo(current + dir); }
document.addEventListener('keydown', e => {
  if (['ArrowRight','ArrowDown',' '].includes(e.key)) { e.preventDefault(); go(1); }
  if (['ArrowLeft','ArrowUp'].includes(e.key)) { e.preventDefault(); go(-1); }
});
let touchX = null;
document.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive:true });
document.addEventListener('touchend', e => {
  if (touchX === null) return;
  const dx = e.changedTouches[0].clientX - touchX;
  if (Math.abs(dx) > 50) go(dx < 0 ? 1 : -1);
  touchX = null;
}, { passive:true });
updateNav();
</script>
